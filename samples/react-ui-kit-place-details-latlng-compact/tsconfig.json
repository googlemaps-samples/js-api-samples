{
    "extends": "../../tsconfig.base.json",
  "compilerOptions": {
      "module": "esnext",
      "target": "esnext",
      "strict": true,
      "noImplicitAny": false,
      "lib": [
        "es2015",
        "esnext",
        "es6",
        "dom",
        "dom.iterable"
      ],
      "moduleResolution": "bundler",
      "jsx": "react-jsx",
      "skipLibCheck": true,
      "allowSyntheticDefaultImports": true,
      "verbatimModuleSyntax": true,
      "types": [
        "vite/client",
        "node",
        "google.maps"
      ]
    },
  }
