{
  "name": "@js-api-samples/map-drawing-terradraw",
  "version": "1.0.0",
  "description": "Basic sample for Terra Draw with Google Maps API.",
  "scripts": {
    "build": "bash ../build-single.sh",
    "test": "tsc && npm run build:vite --workspace=.",
    "start": "tsc && vite build --config ../../vite.config.js --base './' && vite --config ../../vite.config.js",
    "build:vite": "vite build --config ../../vite.config.js --base './'",
    "preview": "vite preview --config ../../vite.config.js"
  },
  "dependencies": {
    "terra-draw": "latest",
    "terra-draw-google-maps-adapter": "latest"
  },
  "devDependencies": {
    "@types/google.maps": "latest",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  },
  "author": "Google LLC"
}
