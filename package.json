    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^7.5.1",
    "@playwright/test": "^1.58.2",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.10",
    "@deck.gl/google-maps": "^9.2.10",
    "@deck.gl/layers": "^9.2.10",
    "deck.gl": "^9.2.11",
    "dotenv": "^17.3.1"
