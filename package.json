    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
