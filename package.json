    "generate-index": "bash samples/generate-index.sh"
  },
  "workspaces": [
    "samples/*"
  ],
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
